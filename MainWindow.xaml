<Window x:Class="SvgEditorSample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simple SVG Editor" Height="600" Width="800">
    <DockPanel>
        <!-- 上部ツールバー -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5">
            <Button Content="矩形追加" Width="80" Margin="5" Click="AddRect_Click"/>
            <Button Content="円追加" Width="80" Margin="5" Click="AddEllipse_Click"/>
            <Button Content="SVG保存" Width="80" Margin="5" Click="SaveSvg_Click"/>
        </StackPanel>

        <!-- 描画エリア -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <Canvas x:Name="DrawCanvas"
                    Background="White"
                    Width="1200" Height="800"
                    MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                    MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                    MouseMove="Canvas_MouseMove"/>
        </ScrollViewer>
    </DockPanel>
</Window>
